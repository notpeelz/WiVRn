+static void
+solarxr_device_send_feedback(struct solarxr_device *const device, const int64_t time)
+{
+	atomic_store(&device->next_feedback, time + debug_get_num_option_solarxr_sync_timeout_ms() * U_TIME_1MS_IN_NS);
+	struct xrt_space_relation head = {0};
+	if (device->hmd == NULL ||
+	    xrt_device_get_tracked_pose(device->hmd, XRT_INPUT_GENERIC_HEAD_POSE, time, &head) != XRT_SUCCESS ||
+	    head.relation_flags == 0) {
+		return;
+	}
+#define FLOAT_TO_BYTES(v) ((uint8_t *)&(v))[0], ((uint8_t *)&(v))[1], ((uint8_t *)&(v))[2], ((uint8_t *)&(v))[3]
+	const uint8_t pkt_position[39] = {
+	    (1 << 3) | 2, sizeof(pkt_position) - 2,
+	    (2 << 3) | 5, FLOAT_TO_BYTES(head.pose.position.x),
+	    (3 << 3) | 5, FLOAT_TO_BYTES(head.pose.position.y),
+	    (4 << 3) | 5, FLOAT_TO_BYTES(head.pose.position.z),
+	    (5 << 3) | 5, FLOAT_TO_BYTES(head.pose.orientation.x),
+	    (6 << 3) | 5, FLOAT_TO_BYTES(head.pose.orientation.y),
+	    (7 << 3) | 5, FLOAT_TO_BYTES(head.pose.orientation.z),
+	    (8 << 3) | 5, FLOAT_TO_BYTES(head.pose.orientation.w),
+	    (9 << 3) | 0, 0x03,
+	};
+#undef FLOAT_TO_BYTES
+	ipc_socket_send(&device->feedback, pkt_position, sizeof(pkt_position));
+}
+
+static void
+solarxr_device_sync(struct solarxr_device *const device)
+{
+	const int64_t time = os_monotonic_get_ns(), next_sync = atomic_exchange(&device->next_sync, INT64_MAX);
+	if (time <= next_sync) {
+		atomic_store(&device->next_sync, next_sync);
+		return;
+	}
+	solarxr_device_send_feedback(device, time);
+	ipc_socket_send(&device->socket, device->poll_packet, device->poll_packet_len);
+	atomic_store(&device->next_sync, time + debug_get_num_option_solarxr_sync_timeout_ms() * U_TIME_1MS_IN_NS);
+}
