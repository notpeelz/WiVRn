+    LEFT_LITTLE_INTERMEDIATE = 38,
+    LEFT_LITTLE_DISTAL = 39,
+    RIGHT_THUMB_PROXIMAL = 40,
+    RIGHT_THUMB_INTERMEDIATE = 41,
