+    mounting_orientation: solarxr_protocol.datatypes.math.Quat;
+    editable: bool;
+    is_computed: bool;
+    is_imu: bool;
+    display_name: string;
+    custom_name: string;
+    allow_drift_compensation: bool;
+    mounting_reset_orientation: solarxr_protocol.datatypes.math.Quat;
+    is_hmd: bool;
+}
+
+namespace solarxr_protocol.data_feed.device_data;
