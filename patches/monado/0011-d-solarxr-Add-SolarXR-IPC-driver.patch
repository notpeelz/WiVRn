+	}
+#ifdef XRT_FEATURE_OPENXR_BODY_TRACKING_FULL_BODY_META
+	case XRT_INPUT_META_FULL_BODY_TRACKING: {
+		joints = out_value->full_body_skeleton_meta.joints;
